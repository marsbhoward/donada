    "rental_validator/RentalDatum": {
      "title": "RentalDatum",
      "description": "Datum stored inline on the rental contract UTXO.",
      "anyOf": [
        {
          "title": "RentalDatum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "nft_policy",
              "description": "The \"donada\" minting policy ID — used to verify the correct NFT is locked.",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "nft_asset_name",
              "description": "The specific asset name of the NFT being listed (e.g. \"DonodaNFT001\").",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "owner",
              "description": "The original NFT owner. Receives 90% of rental_fee and signs CancelListing.",
              "$ref": "#/definitions/cardano~1address~1Address"
            },
            {
              "title": "renter",
              "description": "Set to Some(address) when a renter successfully calls the Rent redeemer.\n None at listing time. First-come-first-served — once set, cannot change.",
              "$ref": "#/definitions/Option<cardano~1address~1Address>"
            },
            {
              "title": "rental_fee",
              "description": "Rental fee in lovelace. Must be paid in full by the renter in one tx.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "draw_date",
              "description": "Cardano POSIX time in milliseconds. After this time the owner or draw\n contract can reclaim the NFT.",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "fee_recipient",
              "description": "Receives 10% of rental_fee on every Rent tx (the project's cold fees/\n treasury wallet). Payment destination only — never used as a signer.",
              "$ref": "#/definitions/cardano~1address~1Address"
            },
            {
              "title": "claim_authority",
              "description": "May co-sign ClaimBack after draw_date, alongside the owner. This is the\n automated draw/hot wallet — signer only, never receives funds here.",
              "$ref": "#/definitions/cardano~1address~1Address"
            }
          ]
        }
      ]
    },
